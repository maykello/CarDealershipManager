@model List<CarDealershipManager.Models.Entities.AdminModel>

@{
    ViewData["Title"] = "Zarządzanie Użytkownikami";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="mb-0">Zarządzanie Użytkownikami</h1>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Dodaj użytkownika
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light border-bottom">
            <h5 class="mb-0">Lista użytkowników</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Login</th>
                                <th>Email</th>
                                <th class="text-end">Akcje</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var admin in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@admin.UserId</strong>
                                    </td>
                                    <td>
                                        <strong>@admin.UserName</strong>
                                    </td>
                                    <td>@(admin.Email ?? "brak")</td>
                                    <td class="text-end">
                                        @if (admin.UserName == "admin")
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-crown me-1"></i> Główny admin
                                            </span>
                                        }
                                        else
                                        {
                                            <form asp-action="Delete" asp-route-id="@admin.UserId" method="post" class="d-inline"
                                                  onsubmit="return confirm('Czy na pewno chcesz usunąć użytkownika @admin.UserName?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="p-4 text-center text-muted">
                    <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                    <p>Brak użytkowników w systemie</p>
                </div>
            }
        </div>
    </div>

    <div class="text-center mt-4">
        <a asp-controller="Admin" asp-action="Panel" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Powrót do panelu
        </a>
    </div>
</div>
