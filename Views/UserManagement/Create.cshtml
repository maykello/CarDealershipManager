@model CarDealershipManager.Models.Dtos.CreateUserDto

@{
    ViewData["Title"] = "Dodaj Użytkownika";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <h3 class="text-center mb-4">Dodaj nowego użytkownika</h3>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white rounded-top">
                    <h5 class="mb-0">Nowe konto</h5>
                </div>
                <div class="card-body bg-light">
                    <div class="alert alert-info">
                        Hasło zostanie wygenerowane automatycznie.
                    </div>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="UserName" class="form-label fw-bold"></label>
                            <input asp-for="UserName" class="form-control" placeholder="Wpisz login" />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold"></label>
                            <input asp-for="Email" class="form-control" type="email" placeholder="Wpisz email (opcjonalnie)" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success btn-lg shadow">Utwórz użytkownika</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-4">
                <a asp-action="Index" class="text-decoration-none">Wróć do listy użytkowników</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
