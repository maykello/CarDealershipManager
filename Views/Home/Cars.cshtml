@model CarDealershipManager.Models.CarSearchResult

@{
    ViewData["Title"] = "Nasze samochody";
}

<div class="container mt-5">
    <h1 class="mb-4">Nasze samochody</h1>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="mb-4">
            <a href="@Url.Action("Create", "Admin")" class="btn btn-success fw-bold p-2">+ Dodaj nowy pojazd</a>
        </div>
    }

    <!-- Search and Filter Form -->
    <div class="mb-3 p-3 border rounded bg-light">
        <h5 class="mb-3">Filtry</h5>
        <form method="get" action="@Url.Action("Cars")" id="filterForm">
            <div class="row">
                <!-- Search Term -->
                <div class="col-md-6 mb-3">
                    <label for="searchTerm" class="form-label">Szukaj (marka/model)</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="searchTerm" placeholder="Szukaj..." name="searchTerm" value="@Model.CurrentFilters.SearchTerm">
                        <button class="btn btn-primary" type="submit">Szukaj</button>
                    </div>
                </div>

                <!-- Make Filter -->
                <div class="col-md-6 mb-3">
                    <label for="makeId" class="form-label">Marka</label>
                    <select class="form-select" id="makeId" name="makeId" onchange="updateModels()">
                        <option value="">-- Wszystkie marki --</option>
                        @foreach (var make in Model.AvailableFilters.Makes)
                        {
                            <option value="@make.MakeId" selected="@(Model.CurrentFilters.MakeId == make.MakeId)">@make.Name</option>
                        }
                    </select>
                </div>

                <!-- Model Filter -->
                <div class="col-md-6 mb-3">
                    <label for="modelId" class="form-label">Model</label>
                    <select class="form-select" id="modelId" name="modelId" onchange="updateGenerations()">
                        <option value="">-- Wszystkie modele --</option>
                        @foreach (var carModel in Model.AvailableFilters.Models)
                        {
                            <option value="@carModel.ModelId" selected="@(Model.CurrentFilters.ModelId == carModel.ModelId)">@carModel.Name</option>
                        }
                    </select>
                </div>

                <!-- Generation Filter -->
                <div class="col-md-6 mb-3">
                    <label for="generationId" class="form-label">Generacja</label>
                    <select class="form-select" id="generationId" name="generationId">
                        <option value="">-- Wszystkie generacje --</option>
                        @foreach (var generation in Model.AvailableFilters.Generations)
                        {
                            <option value="@generation.GenerationId" selected="@(Model.CurrentFilters.GenerationId == generation.GenerationId)">@generation.Name</option>
                        }
                    </select>
                </div>

                <!-- Price Range -->
                <div class="col-md-3 mb-3">
                    <label for="minPrice" class="form-label">Cena od</label>
                    <input type="number" class="form-control" id="minPrice" name="minPrice" placeholder="Min" value="@Model.CurrentFilters.MinPrice?.ToString("0.00")" step="0.01">
                </div>

                <div class="col-md-3 mb-3">
                    <label for="maxPrice" class="form-label">Cena do</label>
                    <input type="number" class="form-control" id="maxPrice" name="maxPrice" placeholder="Max" value="@Model.CurrentFilters.MaxPrice?.ToString("0.00")" step="0.01">
                </div>

                <!-- Year Range -->
                <div class="col-md-3 mb-3">
                    <label for="minYear" class="form-label">Rok od</label>
                    <input type="number" class="form-control" id="minYear" name="minYear" placeholder="Min" value="@Model.CurrentFilters.MinYear">
                </div>

                <div class="col-md-3 mb-3">
                    <label for="maxYear" class="form-label">Rok do</label>
                    <input type="number" class="form-control" id="maxYear" name="maxYear" placeholder="Max" value="@Model.CurrentFilters.MaxYear">
                </div>

                <!-- Fuel Type Filter -->
                <div class="col-md-4 mb-3">
                    <label for="fuelTypeId" class="form-label">Typ paliwa</label>
                    <select class="form-select" id="fuelTypeId" name="fuelTypeId">
                        <option value="">-- Wszystkie typy --</option>
                        @foreach (var fuelType in Model.AvailableFilters.FuelTypes)
                        {
                            <option value="@fuelType.FuelTypeId" selected="@(Model.CurrentFilters.FuelTypeId == fuelType.FuelTypeId)">@fuelType.Name</option>
                        }
                    </select>
                </div>

                <!-- Transmission Filter -->
                <div class="col-md-4 mb-3">
                    <label for="transmissionId" class="form-label">Transmisja</label>
                    <select class="form-select" id="transmissionId" name="transmissionId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var transmission in Model.AvailableFilters.TransmissionTypes)
                        {
                            <option value="@transmission.TransmissionTypeId" selected="@(Model.CurrentFilters.TransmissionId == transmission.TransmissionTypeId)">@transmission.Name</option>
                        }
                    </select>
                </div>

                <!-- Body Type Filter -->
                <div class="col-md-4 mb-3">
                    <label for="bodyTypeId" class="form-label">Typ nadwozia</label>
                    <select class="form-select" id="bodyTypeId" name="bodyTypeId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var bodyType in Model.AvailableFilters.BodyTypes)
                        {
                            <option value="@bodyType.BodyTypeId" selected="@(Model.CurrentFilters.BodyTypeId == bodyType.BodyTypeId)">@bodyType.Name</option>
                        }
                    </select>
                </div>

                <!-- Color Filter -->
                <div class="col-md-4 mb-3">
                    <label for="colorId" class="form-label">Kolor</label>
                    <select class="form-select" id="colorId" name="colorId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var color in Model.AvailableFilters.Colors)
                        {
                            <option value="@color.ColorId" selected="@(Model.CurrentFilters.ColorId == color.ColorId)">@color.Name</option>
                        }
                    </select>
                </div>

                <!-- Drivetrain Filter -->
                <div class="col-md-4 mb-3">
                    <label for="drivetrainId" class="form-label">Napęd</label>
                    <select class="form-select" id="drivetrainId" name="drivetrainId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var drivetrain in Model.AvailableFilters.Drivetrains)
                        {
                            <option value="@drivetrain.DrivetrainId" selected="@(Model.CurrentFilters.DrivetrainId == drivetrain.DrivetrainId)">@drivetrain.Name</option>
                        }
                    </select>
                </div>

                <!-- Euro Class Filter -->
                <div class="col-md-4 mb-3">
                    <label for="euroClassId" class="form-label">Klasa Euro</label>
                    <select class="form-select" id="euroClassId" name="euroClassId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var euroClass in Model.AvailableFilters.EuroClasses)
                        {
                            <option value="@euroClass.EuroClassId" selected="@(Model.CurrentFilters.EuroClassId == euroClass.EuroClassId)">@euroClass.Name</option>
                        }
                    </select>
                </div>

                <!-- Status Filter -->
                <div class="col-md-4 mb-3">
                    <label for="statusId" class="form-label">Status</label>
                    <select class="form-select" id="statusId" name="statusId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var status in Model.AvailableFilters.CarStatuses)
                        {
                            <option value="@status.CarStatusId" selected="@(Model.CurrentFilters.StatusId == status.CarStatusId)">@status.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-8">
                    <button type="submit" class="btn btn-primary">Filtruj</button>
                    <a href="@Url.Action("Cars")" class="btn btn-secondary">Wyczyść filtry</a>
                </div>
                <div class="col-md-4 d-flex align-items-center justify-content-end">
                    <label class="form-label me-2 mb-0"><strong>Elementy na stronie:</strong></label>
                    <div class="btn-group" role="group" aria-label="Wybór liczby elementów">
                        <a href="@Url.Action("Cars", new { pageIndex = 1, pageSize = 10, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })" 
                           class="btn btn-sm @(Model.Cars.PageSize == 10 ? "btn-primary" : "btn-outline-primary")">
                            10
                        </a>
                        <a href="@Url.Action("Cars", new { pageIndex = 1, pageSize = 20, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })" 
                           class="btn btn-sm @(Model.Cars.PageSize == 20 ? "btn-primary" : "btn-outline-primary")">
                            20
                        </a>
                        <a href="@Url.Action("Cars", new { pageIndex = 1, pageSize = 50, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })" 
                           class="btn btn-sm @(Model.Cars.PageSize == 50 ? "btn-primary" : "btn-outline-primary")">
                            50
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <!-- Results Counter -->
    @if (Model != null && Model.Cars.Items.Count > 0)
    {
        <div class="alert alert-primary d-flex justify-content-between align-items-center mb-4">
            <div>
                <strong>Liczba samochodów spełniających filtry:</strong>
                <span class="badge bg-primary fs-6">@Model.Cars.TotalCount</span>
            </div>
            <small class="text-muted">
                Wyświetlane: @Model.Cars.Items.Count z @Model.Cars.TotalCount
            </small>
        </div>
    }

    @if (Model == null || Model.Cars.Items.Count == 0)
    {
        <div class="alert alert-info">
            Brak dostępnych samochodów.
        </div>
    }
    else
    {
        @foreach (var car in Model.Cars.Items)
        {
            <div class="row mb-5 border-bottom pb-4">
                <div class="col-md-5">
                    @if (car.Gallery != null && car.Gallery.Any())
                    {
                        var mainPhoto = car.Gallery.FirstOrDefault(g => g.IsMain) ?? car.Gallery.First();
                        <img src="@mainPhoto.FilePath" class="img-fluid rounded" alt="@car.Generation?.Model?.Make?.Name @car.Generation?.Model?.Name" style="height: 350px; object-fit: cover; width: 100%;">
                    }
                    else
                    {
                        <div class="bg-secondary rounded" style="height: 350px; display: flex; align-items: center; justify-content: center; width: 100%;">
                            <span class="text-white">Brak zdjęcia</span>
                        </div>
                    }
                </div>

                <div class="col-md-7">
                    <a href="@Url.Action("Details", new { id = car.CarId })" class="text-decoration-none text-dark">
                        <h3 class="mb-3">
                            @car.Generation?.Model?.Make?.Name @car.Generation?.Model?.Name
                            @if (!string.IsNullOrEmpty(car.Generation?.Name))
                            {
                                <span>- @car.Generation.Name</span>
                            }
                        </h3>
                    </a>

                    <div class="mb-3">
                        <p class="mb-2"><strong>Rok produkcji:</strong> @car.ProductionYear</p>
                        <p class="mb-2"><strong>Przebieg:</strong> @car.Mileage km</p>
                        <p class="mb-2"><strong>Moc:</strong> @car.HorsePower KM</p>
                        <p class="mb-2"><strong>Paliwo:</strong> @car.FuelType?.Name</p>

                        @if (car.TransmissionType != null)
                        {
                            <p class="mb-2"><strong>Transmisja:</strong> @car.TransmissionType.Name</p>
                        }
                        @if (car.BodyType != null)
                        {
                            <p class="mb-2"><strong>Typ nadwozia:</strong> @car.BodyType.Name</p>
                        }
                        @if (car.Color != null)
                        {
                            <p class="mb-2"><strong>Kolor:</strong> @car.Color.Name</p>
                        }
                        @if (car.Drivetrain != null)
                        {
                            <p class="mb-2"><strong>Napęd:</strong> @car.Drivetrain.Name</p>
                        }
                        @if (car.EuroClass != null)
                        {
                            <p class="mb-2"><strong>Euro klasa:</strong> @car.EuroClass.Name</p>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(car.Description))
                    {
                        <p class="text-muted mb-3">@car.Description</p>
                    }

                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="text-primary mb-0">@car.Price.ToString("C")</h4>
                        <div class="d-flex gap-2 align-items-center">
                            <span class="badge @GetStatusBadgeClass(car.CarStatus?.Name) fs-6">@car.CarStatus?.Name</span>
                            <a href="@Url.Action("Details", new { id = car.CarId })" class="btn btn-sm btn-primary">
                                Szczegóły
                            </a>
                        </div>
                    </div>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                            <a href="@Url.Action("Edit", "Admin", new { id = car.CarId })" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Edytuj
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                                onclick="document.getElementById('deleteCarId').value = '@car.CarId'; document.getElementById('deleteCarName').innerText = '@car.Generation?.Model?.Make?.Name @car.Generation?.Model?.Name';">
                                <i class="bi bi-trash"></i> Usuń
                            </button>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Pagination -->
        <nav aria-label="Page navigation" class="mt-5 mb-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Cars.PageIndex == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Cars", new { pageIndex = 1, pageSize = Model.Cars.PageSize, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>

                <li class="page-item @(!Model.Cars.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Cars", new { pageIndex = Model.Cars.PageIndex - 1, pageSize = Model.Cars.PageSize, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })">
                        Poprzednia
                    </a>
                </li>

                @{
                    int startPage = Math.Max(1, Model.Cars.PageIndex - 2);
                    int endPage = Math.Min(Model.Cars.TotalPages, Model.Cars.PageIndex + 2);

                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Cars", new { pageIndex = 1, pageSize = Model.Cars.PageSize, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.Cars.PageIndex ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Cars", new { pageIndex = i, pageSize = Model.Cars.PageSize, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })">@i</a>
                        </li>
                    }

                    if (endPage < Model.Cars.TotalPages)
                    {
                        if (endPage < Model.Cars.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Cars", new { pageIndex = Model.Cars.TotalPages, pageSize = Model.Cars.PageSize, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })">@Model.Cars.TotalPages</a>
                        </li>
                    }
                }

                <li class="page-item @(!Model.Cars.HasNextPage ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Cars", new { pageIndex = Model.Cars.PageIndex + 1, pageSize = Model.Cars.PageSize, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })">
                        Następna
                    </a>
                </li>

                <li class="page-item @(Model.Cars.PageIndex == Model.Cars.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Cars", new { pageIndex = Model.Cars.TotalPages, pageSize = Model.Cars.PageSize, searchTerm = Model.CurrentFilters.SearchTerm, makeId = Model.CurrentFilters.MakeId, modelId = Model.CurrentFilters.ModelId, generationId = Model.CurrentFilters.GenerationId, minPrice = Model.CurrentFilters.MinPrice, maxPrice = Model.CurrentFilters.MaxPrice, minYear = Model.CurrentFilters.MinYear, maxYear = Model.CurrentFilters.MaxYear, fuelTypeId = Model.CurrentFilters.FuelTypeId, transmissionId = Model.CurrentFilters.TransmissionId, bodyTypeId = Model.CurrentFilters.BodyTypeId, colorId = Model.CurrentFilters.ColorId, drivetrainId = Model.CurrentFilters.DrivetrainId, euroClassId = Model.CurrentFilters.EuroClassId, statusId = Model.CurrentFilters.StatusId })">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<script>
    function updateSelect(selectId, items, idField, nameField, defaultLabel, callback) {
        const select = document.getElementById(selectId);
        const currentValue = select.value;
        const defaultOption = `<option value="">-- ${defaultLabel} --</option>`;

        select.innerHTML = defaultOption;

        items.forEach(item => {
            const option = document.createElement('option');
            option.value = item[idField];
            option.textContent = item[nameField];
            select.appendChild(option);
        });

        if (currentValue && Array.from(select.options).some(opt => opt.value === currentValue)) {
            select.value = currentValue;
        }

        if (callback) callback();
    }

    function updateModels() {
        const makeId = document.getElementById('makeId').value;
        fetch(`@Url.Action("GetModelsByMake", "Home")?makeId=${makeId || ''}`)
            .then(r => r.json())
            .then(data => updateSelect('modelId', data, 'modelId', 'name', 'Wszystkie modele', updateGenerations))
            .catch(e => console.error('Error loading models:', e));
    }

    function updateGenerations() {
        const modelId = document.getElementById('modelId').value;
        fetch(`@Url.Action("GetGenerationsByModel", "Home")?modelId=${modelId || ''}`)
            .then(r => r.json())
            .then(data => updateSelect('generationId', data, 'generationId', 'name', 'Wszystkie generacje'))
            .catch(e => console.error('Error loading generations:', e));
    }

    document.addEventListener('DOMContentLoaded', function() {
        if (document.getElementById('makeId').value) updateModels();
        else if (document.getElementById('modelId').value) updateGenerations();
    });
</script>

<!-- Modal Potwierdzenia Usunięcia -->
@if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="deleteModalLabel">Potwierdź Usunięcie Pojazdu</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zamknij"></button>
                </div>
                <div class="modal-body">
                    Czy na pewno chcesz usunąć pojazd <strong id="deleteCarName"></strong>? Ta operacja nie może być cofnięta.
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <form method="post" action="@Url.Action("Delete", "Admin")" style="display: inline;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" id="deleteCarId" name="id" />
                        <button type="submit" class="btn btn-danger">Usuń Pojazd</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@functions {
    private string GetStatusBadgeClass(string statusName)
    {
        if (string.IsNullOrEmpty(statusName))
            return "badge-status-other";

        return statusName.ToLower() switch
        {
            "dostepny" => "badge-status-available",
            "sprzedany" => "badge-status-sold",
            "zarezerwowany" => "badge-status-reserved",
            "w serwisie" => "badge-status-maintenance",
            _ => "badge-status-other"
        };
    }
}