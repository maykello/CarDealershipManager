@model CarDealershipManager.Models.PaginatedList<CarDealershipManager.Models.Entities.CarModel>

@{
    ViewData["Title"] = "Nasze samochody";
}

<div class="container mt-5">
    <h1 class="mb-4">Nasze samochody</h1>

    <!-- Search and Filter Form -->
    <div class="mb-5 p-4 border rounded bg-light">
        <h5 class="mb-4">Filtry</h5>
        <form method="get" action="@Url.Action("Cars")" id="filterForm">
            <div class="row">
                <!-- Search Term -->
                <div class="col-md-6 mb-3">
                    <label for="searchTerm" class="form-label">Szukaj (marka/model)</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="searchTerm" placeholder="Szukaj..." name="searchTerm" value="@Model.SearchTerm">
                        <button class="btn btn-primary" type="submit">Szukaj</button>
                    </div>
                </div>

                <!-- Make Filter -->
                <div class="col-md-6 mb-3">
                    <label for="makeId" class="form-label">Marka</label>
                    <select class="form-select" id="makeId" name="makeId" onchange="updateModels()">
                        <option value="">-- Wszystkie marki --</option>
                        @foreach (var make in Model.Makes)
                        {
                            <option value="@make.MakeId" selected="@(Model.SelectedMakeId == make.MakeId)">@make.Name</option>
                        }
                    </select>
                </div>

                <!-- Model Filter -->
                <div class="col-md-6 mb-3">
                    <label for="modelId" class="form-label">Model</label>
                    <select class="form-select" id="modelId" name="modelId">
                        <option value="">-- Wszystkie modele --</option>
                        @foreach (var carModel in Model.Models)
                        {
                            <option value="@carModel.ModelId" selected="@(Model.SelectedModelId == carModel.ModelId)">@carModel.Name</option>
                        }
                    </select>
                </div>

                <!-- Price Range -->
                <div class="col-md-3 mb-3">
                    <label for="minPrice" class="form-label">Cena od</label>
                    <input type="number" class="form-control" id="minPrice" name="minPrice" placeholder="Min" value="@Model.MinPrice?.ToString("0.00")" step="0.01">
                </div>

                <div class="col-md-3 mb-3">
                    <label for="maxPrice" class="form-label">Cena do</label>
                    <input type="number" class="form-control" id="maxPrice" name="maxPrice" placeholder="Max" value="@Model.MaxPrice?.ToString("0.00")" step="0.01">
                </div>

                <!-- Year Range -->
                <div class="col-md-3 mb-3">
                    <label for="minYear" class="form-label">Rok od</label>
                    <input type="number" class="form-control" id="minYear" name="minYear" placeholder="Min" value="@Model.MinYear">
                </div>

                <div class="col-md-3 mb-3">
                    <label for="maxYear" class="form-label">Rok do</label>
                    <input type="number" class="form-control" id="maxYear" name="maxYear" placeholder="Max" value="@Model.MaxYear">
                </div>

                <!-- Fuel Type Filter -->
                <div class="col-md-4 mb-3">
                    <label for="fuelTypeId" class="form-label">Typ paliwa</label>
                    <select class="form-select" id="fuelTypeId" name="fuelTypeId">
                        <option value="">-- Wszystkie typy --</option>
                        @foreach (var fuelType in Model.FuelTypes)
                        {
                            <option value="@fuelType.FuelTypeId" selected="@(Model.SelectedFuelTypeId == fuelType.FuelTypeId)">@fuelType.Name</option>
                        }
                    </select>
                </div>

                <!-- Transmission Filter -->
                <div class="col-md-4 mb-3">
                    <label for="transmissionId" class="form-label">Transmisja</label>
                    <select class="form-select" id="transmissionId" name="transmissionId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var transmission in Model.TransmissionTypes)
                        {
                            <option value="@transmission.TransmissionTypeId" selected="@(Model.SelectedTransmissionId == transmission.TransmissionTypeId)">@transmission.Name</option>
                        }
                    </select>
                </div>

                <!-- Body Type Filter -->
                <div class="col-md-4 mb-3">
                    <label for="bodyTypeId" class="form-label">Typ nadwozia</label>
                    <select class="form-select" id="bodyTypeId" name="bodyTypeId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var bodyType in Model.BodyTypes)
                        {
                            <option value="@bodyType.BodyTypeId" selected="@(Model.SelectedBodyTypeId == bodyType.BodyTypeId)">@bodyType.Name</option>
                        }
                    </select>
                </div>

                <!-- Color Filter -->
                <div class="col-md-4 mb-3">
                    <label for="colorId" class="form-label">Kolor</label>
                    <select class="form-select" id="colorId" name="colorId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var color in Model.Colors)
                        {
                            <option value="@color.ColorId" selected="@(Model.SelectedColorId == color.ColorId)">@color.Name</option>
                        }
                    </select>
                </div>

                <!-- Drivetrain Filter -->
                <div class="col-md-4 mb-3">
                    <label for="drivetrainId" class="form-label">Napęd</label>
                    <select class="form-select" id="drivetrainId" name="drivetrainId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var drivetrain in Model.Drivetrains)
                        {
                            <option value="@drivetrain.DrivetrainId" selected="@(Model.SelectedDrivetrainId == drivetrain.DrivetrainId)">@drivetrain.Name</option>
                        }
                    </select>
                </div>

                <!-- Euro Class Filter -->
                <div class="col-md-4 mb-3">
                    <label for="euroClassId" class="form-label">Klasa Euro</label>
                    <select class="form-select" id="euroClassId" name="euroClassId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var euroClass in Model.EuroClasses)
                        {
                            <option value="@euroClass.EuroClassId" selected="@(Model.SelectedEuroClassId == euroClass.EuroClassId)">@euroClass.Name</option>
                        }
                    </select>
                </div>

                <!-- Status Filter -->
                <div class="col-md-4 mb-3">
                    <label for="statusId" class="form-label">Status</label>
                    <select class="form-select" id="statusId" name="statusId">
                        <option value="">-- Wszystkie --</option>
                        @foreach (var status in Model.CarStatuses)
                        {
                            <option value="@status.CarStatusId" selected="@(Model.SelectedStatusId == status.CarStatusId)">@status.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-8">
                    <button type="submit" class="btn btn-primary">Filtruj</button>
                    <a href="@Url.Action("Cars")" class="btn btn-secondary">Wyczyść filtry</a>
                </div>
                <div class="col-md-4 d-flex align-items-center justify-content-end">
                    <label class="form-label me-2 mb-0"><strong>Elementy na stronie:</strong></label>
                    <div class="btn-group" role="group" aria-label="Wybór liczby elementów">
                        <a href="@Url.Action("Cars", new { pageIndex = 1, pageSize = 10, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })" 
                           class="btn btn-sm @(Model.PageSize == 10 ? "btn-primary" : "btn-outline-primary")">
                            10
                        </a>
                        <a href="@Url.Action("Cars", new { pageIndex = 1, pageSize = 20, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })" 
                           class="btn btn-sm @(Model.PageSize == 20 ? "btn-primary" : "btn-outline-primary")">
                            20
                        </a>
                        <a href="@Url.Action("Cars", new { pageIndex = 1, pageSize = 50, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })" 
                           class="btn btn-sm @(Model.PageSize == 50 ? "btn-primary" : "btn-outline-primary")">
                            50
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>

    <!-- Results Counter -->
    @if (Model != null && Model.Items.Count > 0)
    {
        <div class="alert alert-primary d-flex justify-content-between align-items-center mb-4">
            <div>
                <strong>Liczba samochodów spełniających filtry:</strong>
                <span class="badge bg-primary fs-6">@Model.TotalCount</span>
            </div>
            <small class="text-muted">
                Wyświetlane: @Model.Items.Count z @Model.TotalCount
            </small>
        </div>
    }

    @if (Model == null || Model.Items.Count == 0)
    {
        <div class="alert alert-info">
            Brak dostępnych samochodów.
        </div>
    }
    else
    {
        @foreach (var car in Model.Items)
        {
            <div class="row mb-5 border-bottom pb-4">
                <div class="col-md-5">
                    @if (car.Gallery != null && car.Gallery.Any())
                    {
                        <img src="@car.Gallery.First().FilePath" class="img-fluid rounded" alt="@car.Generation?.Model?.Make?.Name @car.Generation?.Model?.Name" style="height: 350px; object-fit: cover; width: 100%;">
                    }
                    else
                    {
                        <div class="bg-secondary rounded" style="height: 350px; display: flex; align-items: center; justify-content: center; width: 100%;">
                            <span class="text-white">Brak zdjęcia</span>
                        </div>
                    }
                </div>

                <div class="col-md-7">
                    <h3 class="mb-3">
                        @car.Generation?.Model?.Make?.Name @car.Generation?.Model?.Name
                        @if (!string.IsNullOrEmpty(car.Generation?.Name))
                        {
                            <span>- @car.Generation.Name</span>
                        }
                    </h3>

                    <div class="mb-3">
                        <p class="mb-2"><strong>Rok produkcji:</strong> @car.ProductionYear</p>
                        <p class="mb-2"><strong>Przebieg:</strong> @car.Mileage km</p>
                        <p class="mb-2"><strong>Moc:</strong> @car.HorsePower KM</p>
                        <p class="mb-2"><strong>Paliwo:</strong> @car.FuelType?.Name</p>

                        @if (car.TransmissionType != null)
                        {
                            <p class="mb-2"><strong>Transmisja:</strong> @car.TransmissionType.Name</p>
                        }
                        @if (car.BodyType != null)
                        {
                            <p class="mb-2"><strong>Typ nadwozia:</strong> @car.BodyType.Name</p>
                        }
                        @if (car.Color != null)
                        {
                            <p class="mb-2"><strong>Kolor:</strong> @car.Color.Name</p>
                        }
                        @if (car.Drivetrain != null)
                        {
                            <p class="mb-2"><strong>Napęd:</strong> @car.Drivetrain.Name</p>
                        }
                        @if (car.EuroClass != null)
                        {
                            <p class="mb-2"><strong>Euro klasa:</strong> @car.EuroClass.Name</p>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(car.Description))
                    {
                        <p class="text-muted mb-3">@car.Description</p>
                    }

                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="text-primary mb-0">@car.Price.ToString("C")</h4>
                        <span class="badge bg-success fs-6">@car.CarStatus?.Name</span>
                    </div>
                </div>
            </div>
        }

        <!-- Pagination -->
        <nav aria-label="Page navigation" class="mt-5 mb-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.PageIndex == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Cars", new { pageIndex = 1, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })">
                        <span aria-hidden="true">&laquo;</span>
                    </a>
                </li>

                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Cars", new { pageIndex = Model.PageIndex - 1, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })">
                        Poprzednia
                    </a>
                </li>

                @{
                    int startPage = Math.Max(1, Model.PageIndex - 2);
                    int endPage = Math.Min(Model.TotalPages, Model.PageIndex + 2);

                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Cars", new { pageIndex = 1, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Cars", new { pageIndex = i, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })">@i</a>
                        </li>
                    }

                    if (endPage < Model.TotalPages)
                    {
                        if (endPage < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Cars", new { pageIndex = Model.TotalPages, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })">@Model.TotalPages</a>
                        </li>
                    }
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Cars", new { pageIndex = Model.PageIndex + 1, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })">
                        Następna
                    </a>
                </li>

                <li class="page-item @(Model.PageIndex == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("Cars", new { pageIndex = Model.TotalPages, pageSize = Model.PageSize, searchTerm = Model.SearchTerm, makeId = Model.SelectedMakeId, modelId = Model.SelectedModelId, minPrice = Model.MinPrice, maxPrice = Model.MaxPrice, minYear = Model.MinYear, maxYear = Model.MaxYear, fuelTypeId = Model.SelectedFuelTypeId, transmissionId = Model.SelectedTransmissionId, bodyTypeId = Model.SelectedBodyTypeId, colorId = Model.SelectedColorId, drivetrainId = Model.SelectedDrivetrainId, euroClassId = Model.SelectedEuroClassId, statusId = Model.SelectedStatusId })">
                        <span aria-hidden="true">&raquo;</span>
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

<script>
    function updateModels() {
        const makeId = document.getElementById('makeId').value;
        const modelSelect = document.getElementById('modelId');

        if (makeId === '') {
            // Jeśli nie wybrano marki, wyświetl wszystkie modele
            fetch('@Url.Action("GetModelsByMake", "Home")?makeId=')
                .then(response => response.json())
                .then(data => {
                    updateModelSelect(data);
                });
        } else {
            // Pobierz modele dla wybranej marki
            fetch('@Url.Action("GetModelsByMake", "Home")?makeId=' + makeId)
                .then(response => response.json())
                .then(data => {
                    updateModelSelect(data);
                });
        }
    }

    function updateModelSelect(models) {
        const modelSelect = document.getElementById('modelId');
        const currentSelectedId = modelSelect.value;

        // Wyczyść opcje oprócz domyślnej
        modelSelect.innerHTML = '<option value="">-- Wszystkie modele --</option>';

        // Dodaj nowe opcje
        models.forEach(model => {
            const option = document.createElement('option');
            option.value = model.modelId;
            option.textContent = model.name;
            modelSelect.appendChild(option);
        });

        // Przywróć poprzednio wybraną wartość jeśli istnieje
        if (currentSelectedId) {
            const optionExists = Array.from(modelSelect.options).some(opt => opt.value === currentSelectedId);
            if (optionExists) {
                modelSelect.value = currentSelectedId;
            }
        }
    }

    // Inicjalizuj modele przy wczytaniu strony
    document.addEventListener('DOMContentLoaded', function() {
        const makeId = document.getElementById('makeId').value;
        if (makeId) {
            updateModels();
        }
    });
</script>