@model List<CarDealershipManager.Models.Dtos.GalleryDto>

@{
    ViewData["Title"] = "Strona główna - CarDealership Manager";
}

<!-- HERO SECTION -->
<section class="hero animate-fade-in">
    <div class="hero-content">
        <h1>Znajdź swój wymarzony samochód</h1>
        <p>Profesjonalny system zarządzania komisem samochodów z szeroką ofertą pojazdów wysokiej jakości</p>
        <div class="hero-cta">
            <a href="@Url.Action("Cars", "Home")" class="btn btn-primary btn-lg">
                <i class="fas fa-car me-2"></i> Przeglądaj ofertę
            </a>
        </div>
    </div>
</section>

<!-- CAROUSEL ZDJĘĆ - MINI GALERIA -->
<section style="margin-top: 3rem; padding: 2rem 0; overflow: hidden;">
    <div class="text-center mb-4">
        <h3 style="color: var(--color-navy-light);">Nasze pojazdy</h3>
        <p style="color: var(--color-gray-medium);">Przejrzyj galerię naszych pojazdów</p>
    </div>

    <div class="infinite-carousel">
        <div class="carousel-track">
            @if (Model != null && Model.Count > 0)
            {
                @for (int i = 0; i < 2; i++)
                {
                    @foreach (var photo in Model)
                    {
                        <div class="carousel-slide">
                            <img src="@photo.FilePath" alt="Samochód" class="carousel-image">
                        </div>
                    }
                }
            }
        </div>
    </div>
</section>

