@model CarDealershipManager.Models.Dtos.CarDto

@{
    ViewData["Title"] = $"{Model.Generation?.Model?.Make?.Name} {Model.Generation?.Model?.Name} {Model.Generation?.Name}";
}

<div class="container mt-5 mb-5">
    <!-- Header Section -->
    <div class="row mb-5">
        <div class="col-md-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Cars")">Nasze samochody</a></li>
                    <li class="breadcrumb-item active" aria-current="page">
                        @Model.Generation?.Model?.Make?.Name @Model.Generation?.Model?.Name 
                        @if (!string.IsNullOrEmpty(Model.Generation?.Name))
                        {
                            <span>@Model.Generation.Name</span>
                        }
                    </li>
                </ol>
            </nav>

            <div class="d-flex justify-content-between align-items-center">
                <h1 class="mb-3">
                    @Model.Generation?.Model?.Make?.Name @Model.Generation?.Model?.Name
                    @if (!string.IsNullOrEmpty(Model.Generation?.Name))
                    {
                        <span>- @Model.Generation.Name</span>
                    }
                </h1>
                <div class="d-flex align-items-center gap-3">
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div>
                            <a href="@Url.Action("Edit", "Admin", new { id = Model.CarId })" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Edytuj
                            </a>
                            <a href="@Url.Action("GenerateInvoice", "Admin", new { carId = Model.CarId })" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-file-pdf"></i> Faktura VAT
                            </a>
                            <form asp-action="Delete" asp-controller="Admin" asp-route-id="@Model.CarId" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć ten pojazd?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i> Usuń
                                </button>
                            </form>
                        </div>
                    }
                    <span class="badge @GetStatusBadgeClass(Model.CarStatus?.Name) fs-5">@Model.CarStatus?.Name</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Gallery Section -->
    <div class="row mb-5">
        <div class="col-md-8">
            @{
                var orderedGallery = Model.Gallery?.OrderByDescending(g => g.IsMain).ToList();
            }
            @if (orderedGallery != null && orderedGallery.Any())
            {
                <div id="carGalleryCarousel" class="carousel slide" data-bs-ride="carousel">
                    <!-- Images -->
                    <div class="carousel-inner bg-dark rounded">
                        @foreach (var (image, index) in orderedGallery.Select((x, i) => (x, i)))
                        {
                            <div class="carousel-item @(index == 0 ? "active" : "")">
                                <img src="@image.FilePath" class="d-block w-100" style="height: 500px; object-fit: cover; cursor: pointer;" alt="Zdjęcie pojazdu" loading="lazy" data-bs-toggle="modal" data-bs-target="#galleryModal">
                            </div>
                        }
                    </div>

                    <!-- Navigation -->
                    @if (orderedGallery.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#carGalleryCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Poprzednie</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carGalleryCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Następne</span>
                        </button>
                    }
                </div>

                <!-- Thumbnails (Bootstrap flex) -->
                @if (orderedGallery.Count > 1)
                {
                    <div class="d-flex overflow-auto gap-2 mt-2 pb-2">
                        @foreach (var (image, index) in orderedGallery.Select((x, i) => (x, i)))
                        {
                            <img src="@image.FilePath" 
                                 class="rounded border border-secondary" 
                                 style="width: 80px; height: 60px; object-fit: cover; cursor: pointer; opacity: 0.8;" 
                                 onmouseover="this.style.opacity='1'" 
                                 onmouseout="this.style.opacity='0.8'"
                                 data-bs-target="#carGalleryCarousel" 
                                 data-bs-slide-to="@index" 
                                 alt="Miniaturka">
                        }
                    </div>
                }
            }
            else
            {
                <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="height: 500px;">
                    <span class="text-white fs-5">Brak zdjęcia</span>
                </div>
            }
        </div>

        <!-- Price and Quick Info -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="text-primary mb-4">@Model.Price.ToString("C")</h2>

                    <hr>

                    <div class="mb-3">
                        <p class="text-muted mb-1"><strong>Liczba ofert:</strong></p>
                        <p class="fs-5">1</p>
                    </div>

                    <div class="mb-3">
                        <p class="text-muted mb-1"><strong>Numer VIN:</strong></p>
                        <p class="fs-6 font-monospace">@Model.Vin</p>
                    </div>

                    <hr>

                    <a href="@Url.Action("Cars")" class="btn btn-outline-secondary w-100">
                        Powrót do listy
                    </a>
                </div>
            </div>

            <!-- Key Specs Card -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Kluczowe informacje</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <strong>Rok:</strong> <span class="float-end">@Model.ProductionYear</span>
                        </li>
                        <li class="mb-2">
                            <strong>Przebieg:</strong> <span class="float-end">@Model.Mileage.ToString("N0") km</span>
                        </li>
                        <li class="mb-2">
                            <strong>Moc:</strong> <span class="float-end">@Model.HorsePower KM</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Detailed Specifications Section -->
    <div class="row mb-5">
        <div class="col-md-12">
            <h3 class="mb-4">Szczegółowe parametry</h3>

            <div class="row">
                <!-- Engine & Performance -->
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Silnik i Wydajność</h5>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-6">
                                    <p class="text-muted mb-1"><small>Moc silnika</small></p>
                                    <p class="fs-5 mb-0"><strong>@Model.HorsePower KM</strong></p>
                                </div>
                                <div class="col-6">
                                    <p class="text-muted mb-1"><small>Typ paliwa</small></p>
                                    <p class="fs-5 mb-0"><strong>@Model.FuelType?.Name</strong></p>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <p class="text-muted mb-1"><small>Przebieg</small></p>
                                    <p class="fs-5 mb-0"><strong>@Model.Mileage.ToString("N0") km</strong></p>
                                </div>
                                <div class="col-6">
                                    <p class="text-muted mb-1"><small>Rok produkcji</small></p>
                                    <p class="fs-5 mb-0"><strong>@Model.ProductionYear</strong></p>
                                </div>
                            </div>
                            @if (Model.EuroClass != null)
                            {
                                <div class="row">
                                    <div class="col-6">
                                        <p class="text-muted mb-1"><small>Klasa Euro</small></p>
                                        <p class="fs-5 mb-0"><strong>@Model.EuroClass.Name</strong></p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Transmission & Drivetrain -->
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Transmisja i Napęd</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.TransmissionType != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <p class="text-muted mb-1"><small>Typ transmisji</small></p>
                                        <p class="fs-5 mb-0"><strong>@Model.TransmissionType.Name</strong></p>
                                    </div>
                                </div>
                            }
                            @if (Model.Drivetrain != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <p class="text-muted mb-1"><small>Napęd</small></p>
                                        <p class="fs-5 mb-0"><strong>@Model.Drivetrain.Name</strong></p>
                                    </div>
                                </div>
                            }
                            @if (Model.TransmissionType == null && Model.Drivetrain == null)
                            {
                                <p class="text-muted">Brak dostępnych informacji</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Body & Appearance -->
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Wygląd i Nadwozie</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.BodyType != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-6">
                                        <p class="text-muted mb-1"><small>Typ nadwozia</small></p>
                                        <p class="fs-5 mb-0"><strong>@Model.BodyType.Name</strong></p>
                                    </div>
                                </div>
                            }
                            @if (Model.Color != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-6">
                                        <p class="text-muted mb-1"><small>Kolor</small></p>
                                        <div class="d-flex align-items-center">
                                            <div class="rounded me-2" style="width: 30px; height: 30px; background-color: @GetColorHex(Model.Color.Name); border: 1px solid #ddd;"></div>
                                            <strong>@Model.Color.Name</strong>
                                        </div>
                                    </div>
                                </div>
                            }
                            @if (Model.BodyType == null && Model.Color == null)
                            {
                                <p class="text-muted">Brak dostępnych informacji</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Price & Status -->
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Cena i Status</h5>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-12">
                                    <p class="text-muted mb-1"><small>Cena</small></p>
                                    <p class="fs-3 mb-0 text-primary"><strong>@Model.Price.ToString("C")</strong></p>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <p class="text-muted mb-1"><small>Status pojazdu</small></p>
                                    <span class="badge @GetStatusBadgeClass(Model.CarStatus?.Name) fs-6">@Model.CarStatus?.Name</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Description Section -->
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="row mb-5">
            <div class="col-md-12">
                <h3 class="mb-3">Opis pojazdu</h3>
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <p class="card-text">@Html.Raw(Model.Description.Replace("\n", "<br>"))</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Specifications Summary Table -->
    <div class="row mb-5">
        <div class="col-md-12">
            <h3 class="mb-3">Pełna specyfikacja</h3>
            <div class="table-responsive">
                <table class="table table-hover border">
                    <tbody>
                        <tr>
                            <th style="width: 40%;">Parametr</th>
                            <th style="width: 60%;">Wartość</th>
                        </tr>
                        <tr>
                            <td><strong>Marka</strong></td>
                            <td>@Model.Generation?.Model?.Make?.Name</td>
                        </tr>
                        <tr>
                            <td><strong>Model</strong></td>
                            <td>@Model.Generation?.Model?.Name</td>
                        </tr>
                        @if (!string.IsNullOrEmpty(Model.Generation?.Name))
                        {
                            <tr>
                                <td><strong>Generacja</strong></td>
                                <td>@Model.Generation.Name</td>
                            </tr>
                        }
                        <tr>
                            <td><strong>Rok produkcji</strong></td>
                            <td>@Model.ProductionYear</td>
                        </tr>
                        <tr>
                            <td><strong>Przebieg</strong></td>
                            <td>@Model.Mileage.ToString("N0") km</td>
                        </tr>
                        <tr>
                            <td><strong>VIN</strong></td>
                            <td class="font-monospace">@Model.Vin</td>
                        </tr>
                        <tr>
                            <td><strong>Moc silnika</strong></td>
                            <td>@Model.HorsePower KM</td>
                        </tr>
                        <tr>
                            <td><strong>Typ paliwa</strong></td>
                            <td>@Model.FuelType?.Name</td>
                        </tr>
                        @if (Model.TransmissionType != null)
                        {
                            <tr>
                                <td><strong>Transmisja</strong></td>
                                <td>@Model.TransmissionType.Name</td>
                            </tr>
                        }
                        @if (Model.BodyType != null)
                        {
                            <tr>
                                <td><strong>Typ nadwozia</strong></td>
                                <td>@Model.BodyType.Name</td>
                            </tr>
                        }
                        @if (Model.Color != null)
                        {
                            <tr>
                                <td><strong>Kolor</strong></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded me-2" style="width: 20px; height: 20px; background-color: @GetColorHex(Model.Color.Name); border: 1px solid #ddd;"></div>
                                        @Model.Color.Name
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (Model.Drivetrain != null)
                        {
                            <tr>
                                <td><strong>Napęd</strong></td>
                                <td>@Model.Drivetrain.Name</td>
                            </tr>
                        }
                        @if (Model.EuroClass != null)
                        {
                            <tr>
                                <td><strong>Klasa Euro</strong></td>
                                <td>@Model.EuroClass.Name</td>
                            </tr>
                        }
                        <tr>
                            <td><strong>Cena</strong></td>
                            <td class="text-primary"><strong>@Model.Price.ToString("C")</strong></td>
                        </tr>
                        <tr>
                            <td><strong>Status</strong></td>
                            <td><span class="badge bg-success">@Model.CarStatus?.Name</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Fullscreen Gallery Modal -->
<div class="modal fade" id="galleryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content bg-dark">
            <div class="modal-header border-0 pb-0">
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zamknij"></button>
            </div>
            <div class="modal-body d-flex flex-column justify-content-center align-items-center pt-0">
                <div id="modalCarousel" class="carousel slide w-100" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @if (Model.Gallery != null)
                        {
                            var orderedGalleryModal = Model.Gallery.OrderByDescending(g => g.IsMain).ToList();
                            @foreach (var (image, index) in orderedGalleryModal.Select((x, i) => (x, i)))
                            {
                                <div class="carousel-item @(index == 0 ? "active" : "")">
                                    <img src="@image.FilePath" class="d-block w-100" style="height: 75vh; object-fit: contain;" alt="Zdjęcie pojazdu">
                                </div>
                            }
                        }
                    </div>
                    @if (Model.Gallery != null && Model.Gallery.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#modalCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Poprzednie</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#modalCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Następne</span>
                        </button>
                    }
                </div>
                
                <!-- Modal Thumbnails -->
                @if (Model.Gallery != null && Model.Gallery.Count > 1)
                {
                    var orderedGalleryModal = Model.Gallery.OrderByDescending(g => g.IsMain).ToList();
                    <div class="d-flex overflow-auto gap-2 mt-3 pb-2 justify-content-center w-100">
                        @foreach (var (image, index) in orderedGalleryModal.Select((x, i) => (x, i)))
                        {
                            <img src="@image.FilePath" 
                                 class="rounded border border-secondary" 
                                 style="width: 80px; height: 60px; object-fit: cover; cursor: pointer; opacity: 0.8;" 
                                 onmouseover="this.style.opacity='1'" 
                                 onmouseout="this.style.opacity='0.8'"
                                 data-bs-target="#modalCarousel" 
                                 data-bs-slide-to="@index" 
                                 alt="Miniaturka">
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const galleryModal = document.getElementById('galleryModal');
    const modalCarousel = document.getElementById('modalCarousel');
    const mainCarousel = document.getElementById('carGalleryCarousel');

    if (galleryModal && modalCarousel && mainCarousel) {
        galleryModal.addEventListener('show.bs.modal', function () {
            const activeItem = mainCarousel.querySelector('.carousel-item.active');
            const items = Array.from(mainCarousel.querySelectorAll('.carousel-item'));
            const index = items.indexOf(activeItem);
            
            const bsModalCarousel = bootstrap.Carousel.getOrCreateInstance(modalCarousel);
            bsModalCarousel.to(index);
        });
    }
</script>
}

@functions {
    private string GetStatusBadgeClass(string statusName)
    {
        if (string.IsNullOrEmpty(statusName))
            return "badge-status-other";

        return statusName.ToLower() switch
        {
            "dostepny" => "badge-status-available",
            "sprzedany" => "badge-status-sold",
            "zarezerwowany" => "badge-status-reserved",
            "w serwisie" => "badge-status-maintenance",
            _ => "badge-status-other"
        };
    }

    private string GetColorHex(string colorName)
    {
        var colors = new Dictionary<string, string>
        {
            { "Czarny", "#000000" },
            { "Biały", "#FFFFFF" },
            { "Szary", "#808080" },
            { "Srebrny", "#C0C0C0" },
            { "Czerwony", "#FF0000" },
            { "Niebieski", "#0000FF" },
            { "Zielony", "#008000" },
            { "Żółty", "#FFFF00" },
            { "Pomarańczowy", "#FFA500" },
            { "Brązowy", "#8B4513" }
        };

        if (colors.TryGetValue(colorName, out var hex))
            return hex;

        return "#CCCCCC";
    }
}
