@model CarDealershipManager.Models.Dtos.CarDto

@{
    ViewData["Title"] = $"{Model.Generation?.Model?.Make?.Name} {Model.Generation?.Model?.Name} {Model.Generation?.Name}";
}

<div class="container mt-5 mb-5">
    <!-- Header Section -->
    <div class="row mb-5">
        <div class="col-md-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Cars")">Nasze samochody</a></li>
                    <li class="breadcrumb-item active" aria-current="page">
                        @Model.Generation?.Model?.Make?.Name @Model.Generation?.Model?.Name 
                        @if (!string.IsNullOrEmpty(Model.Generation?.Name))
                        {
                            <span>@Model.Generation.Name</span>
                        }
                    </li>
                </ol>
            </nav>

            <div class="d-flex justify-content-between align-items-center">
                <h1 class="mb-3">
                    @Model.Generation?.Model?.Make?.Name @Model.Generation?.Model?.Name
                    @if (!string.IsNullOrEmpty(Model.Generation?.Name))
                    {
                        <span>- @Model.Generation.Name</span>
                    }
                </h1>
                <span class="badge bg-success fs-5">@Model.CarStatus?.Name</span>
            </div>
        </div>
    </div>

    <!-- Gallery Section -->
    <div class="row mb-5">
        <div class="col-md-8">
            @if (Model.Gallery != null && Model.Gallery.Any())
            {
                <div id="carGallery" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @foreach (var (image, index) in Model.Gallery.Select((x, i) => (x, i)))
                        {
                            <div class="carousel-item @(index == 0 ? "active" : "")">
                                <img src="@image.FilePath" class="d-block w-100 rounded" alt="@Model.Generation?.Model?.Make?.Name @Model.Generation?.Model?.Name" style="height: 500px; object-fit: cover;">
                            </div>
                        }
                    </div>
                    @if (Model.Gallery.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#carGallery" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Poprzednia</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carGallery" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Następna</span>
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="bg-secondary rounded d-flex align-items-center justify-content-center" style="height: 500px;">
                    <span class="text-white fs-5">Brak zdjęcia</span>
                </div>
            }
        </div>

        <!-- Price and Quick Info -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h2 class="text-primary mb-4">@Model.Price.ToString("C")</h2>

                    <hr>

                    <div class="mb-3">
                        <p class="text-muted mb-1"><strong>Liczba ofert:</strong></p>
                        <p class="fs-5">1</p>
                    </div>

                    <div class="mb-3">
                        <p class="text-muted mb-1"><strong>Numer VIN:</strong></p>
                        <p class="fs-6 font-monospace">@Model.Vin</p>
                    </div>

                    <hr>

                    <a href="@Url.Action("Cars")" class="btn btn-outline-secondary w-100">
                        Powrót do listy
                    </a>
                </div>
            </div>

            <!-- Key Specs Card -->
            <div class="card border-0 shadow-sm mt-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Kluczowe informacje</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <strong>Rok:</strong> <span class="float-end">@Model.ProductionYear</span>
                        </li>
                        <li class="mb-2">
                            <strong>Przebieg:</strong> <span class="float-end">@Model.Mileage.ToString("N0") km</span>
                        </li>
                        <li class="mb-2">
                            <strong>Moc:</strong> <span class="float-end">@Model.HorsePower KM</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Detailed Specifications Section -->
    <div class="row mb-5">
        <div class="col-md-12">
            <h3 class="mb-4">Szczegółowe parametry</h3>

            <div class="row">
                <!-- Engine & Performance -->
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Silnik i Wydajność</h5>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-6">
                                    <p class="text-muted mb-1"><small>Moc silnika</small></p>
                                    <p class="fs-5 mb-0"><strong>@Model.HorsePower KM</strong></p>
                                </div>
                                <div class="col-6">
                                    <p class="text-muted mb-1"><small>Typ paliwa</small></p>
                                    <p class="fs-5 mb-0"><strong>@Model.FuelType?.Name</strong></p>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-6">
                                    <p class="text-muted mb-1"><small>Przebieg</small></p>
                                    <p class="fs-5 mb-0"><strong>@Model.Mileage.ToString("N0") km</strong></p>
                                </div>
                                <div class="col-6">
                                    <p class="text-muted mb-1"><small>Rok produkcji</small></p>
                                    <p class="fs-5 mb-0"><strong>@Model.ProductionYear</strong></p>
                                </div>
                            </div>
                            @if (Model.EuroClass != null)
                            {
                                <div class="row">
                                    <div class="col-6">
                                        <p class="text-muted mb-1"><small>Klasa Euro</small></p>
                                        <p class="fs-5 mb-0"><strong>@Model.EuroClass.Name</strong></p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Transmission & Drivetrain -->
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Transmisja i Napęd</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.TransmissionType != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <p class="text-muted mb-1"><small>Typ transmisji</small></p>
                                        <p class="fs-5 mb-0"><strong>@Model.TransmissionType.Name</strong></p>
                                    </div>
                                </div>
                            }
                            @if (Model.Drivetrain != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <p class="text-muted mb-1"><small>Napęd</small></p>
                                        <p class="fs-5 mb-0"><strong>@Model.Drivetrain.Name</strong></p>
                                    </div>
                                </div>
                            }
                            @if (Model.TransmissionType == null && Model.Drivetrain == null)
                            {
                                <p class="text-muted">Brak dostępnych informacji</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Body & Appearance -->
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Wygląd i Nadwozie</h5>
                        </div>
                        <div class="card-body">
                            @if (Model.BodyType != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-6">
                                        <p class="text-muted mb-1"><small>Typ nadwozia</small></p>
                                        <p class="fs-5 mb-0"><strong>@Model.BodyType.Name</strong></p>
                                    </div>
                                </div>
                            }
                            @if (Model.Color != null)
                            {
                                <div class="row mb-3">
                                    <div class="col-6">
                                        <p class="text-muted mb-1"><small>Kolor</small></p>
                                        <div class="d-flex align-items-center">
                                            <div class="rounded me-2" style="width: 30px; height: 30px; background-color: @GetColorHex(Model.Color.Name); border: 1px solid #ddd;"></div>
                                            <strong>@Model.Color.Name</strong>
                                        </div>
                                    </div>
                                </div>
                            }
                            @if (Model.BodyType == null && Model.Color == null)
                            {
                                <p class="text-muted">Brak dostępnych informacji</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Price & Status -->
                <div class="col-md-6 mb-4">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Cena i Status</h5>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-12">
                                    <p class="text-muted mb-1"><small>Cena</small></p>
                                    <p class="fs-3 mb-0 text-primary"><strong>@Model.Price.ToString("C")</strong></p>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <p class="text-muted mb-1"><small>Status pojazdu</small></p>
                                    <span class="badge bg-success fs-6">@Model.CarStatus?.Name</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Description Section -->
    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="row mb-5">
            <div class="col-md-12">
                <h3 class="mb-3">Opis pojazdu</h3>
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <p class="card-text">@Html.Raw(Model.Description.Replace("\n", "<br>"))</p>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Specifications Summary Table -->
    <div class="row mb-5">
        <div class="col-md-12">
            <h3 class="mb-3">Pełna specyfikacja</h3>
            <div class="table-responsive">
                <table class="table table-hover border">
                    <tbody>
                        <tr>
                            <th style="width: 40%;">Parametr</th>
                            <th style="width: 60%;">Wartość</th>
                        </tr>
                        <tr>
                            <td><strong>Marka</strong></td>
                            <td>@Model.Generation?.Model?.Make?.Name</td>
                        </tr>
                        <tr>
                            <td><strong>Model</strong></td>
                            <td>@Model.Generation?.Model?.Name</td>
                        </tr>
                        @if (!string.IsNullOrEmpty(Model.Generation?.Name))
                        {
                            <tr>
                                <td><strong>Generacja</strong></td>
                                <td>@Model.Generation.Name</td>
                            </tr>
                        }
                        <tr>
                            <td><strong>Rok produkcji</strong></td>
                            <td>@Model.ProductionYear</td>
                        </tr>
                        <tr>
                            <td><strong>Przebieg</strong></td>
                            <td>@Model.Mileage.ToString("N0") km</td>
                        </tr>
                        <tr>
                            <td><strong>VIN</strong></td>
                            <td class="font-monospace">@Model.Vin</td>
                        </tr>
                        <tr>
                            <td><strong>Moc silnika</strong></td>
                            <td>@Model.HorsePower KM</td>
                        </tr>
                        <tr>
                            <td><strong>Typ paliwa</strong></td>
                            <td>@Model.FuelType?.Name</td>
                        </tr>
                        @if (Model.TransmissionType != null)
                        {
                            <tr>
                                <td><strong>Transmisja</strong></td>
                                <td>@Model.TransmissionType.Name</td>
                            </tr>
                        }
                        @if (Model.BodyType != null)
                        {
                            <tr>
                                <td><strong>Typ nadwozia</strong></td>
                                <td>@Model.BodyType.Name</td>
                            </tr>
                        }
                        @if (Model.Color != null)
                        {
                            <tr>
                                <td><strong>Kolor</strong></td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="rounded me-2" style="width: 20px; height: 20px; background-color: @GetColorHex(Model.Color.Name); border: 1px solid #ddd;"></div>
                                        @Model.Color.Name
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (Model.Drivetrain != null)
                        {
                            <tr>
                                <td><strong>Napęd</strong></td>
                                <td>@Model.Drivetrain.Name</td>
                            </tr>
                        }
                        @if (Model.EuroClass != null)
                        {
                            <tr>
                                <td><strong>Klasa Euro</strong></td>
                                <td>@Model.EuroClass.Name</td>
                            </tr>
                        }
                        <tr>
                            <td><strong>Cena</strong></td>
                            <td class="text-primary"><strong>@Model.Price.ToString("C")</strong></td>
                        </tr>
                        <tr>
                            <td><strong>Status</strong></td>
                            <td><span class="badge bg-success">@Model.CarStatus?.Name</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
}

@functions {
    private string GetColorHex(string colorName)
    {
        var colors = new Dictionary<string, string>
        {
            { "Czarny", "#000000" },
            { "Biały", "#FFFFFF" },
            { "Szary", "#808080" },
            { "Srebrny", "#C0C0C0" },
            { "Czerwony", "#FF0000" },
            { "Niebieski", "#0000FF" },
            { "Zielony", "#008000" },
            { "Żółty", "#FFFF00" },
            { "Pomarańczowy", "#FFA500" },
            { "Brązowy", "#8B4513" }
        };

        if (colors.TryGetValue(colorName, out var hex))
            return hex;

        return "#CCCCCC";
    }
}
