@model IEnumerable<CarDealershipManager.Models.Entities.CustomerModel>

@{
    ViewData["Title"] = "Klienci";
}

<div class="container mt-4">
    <h2>Klienci i Firmy</h2>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            @TempData["ErrorMessage"]
        </div>
    }

    <p>
        <a asp-action="Create" class="btn btn-primary">Dodaj Nowego Klienta</a>
    </p>
    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Typ</th>
                <th>Nazwa / Imię i Nazwisko</th>
                <th>Email</th>
                <th>Telefon</th>
                <th>Miasto</th>
                <th>Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model) {
                var isOurCompany = (item.Id == 1);
                var rowClass = isOurCompany ? "table-warning" : "";

                <tr class="@rowClass">
                    <td>
                        @Html.DisplayFor(modelItem => item.Id)
                        @if (isOurCompany)
                        {
                            <span class="badge bg-secondary ms-1">Nasza Firma</span>
                        }
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Type)</td>
                    <td>
                        @if (item.Type == CarDealershipManager.Models.Entities.CustomerType.Company)
                        {
                            @Html.DisplayFor(modelItem => item.CompanyName)
                        }
                        else
                        {
                            @Html.Raw($"{item.FirstName} {item.LastName}")
                        }
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Email)</td>
                    <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                    <td>@Html.DisplayFor(modelItem => item.City)</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edytuj</a>
                        @if (!isOurCompany)
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Usuń</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
